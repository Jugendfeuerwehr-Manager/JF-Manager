# PostgreSQL Configuration
POSTGRES_DB=jf_manager_backend
POSTGRES_USER=jf_manager
POSTGRES_PASSWORD=your_secure_password_here

# Django Configuration
DJANGO_MANAGEPY_MIGRATE=on
DJANGO_ADMIN_PASSWORD=your_admin_password_here
DJANGO_ADMIN_EMAIL=admin@yourdomain.com
DJANGO_SECRET_KEY=your_long_random_secret_key_here

# Redis (used for caching and RQ background workers)
# In production this is set via docker-compose; in dev point to a local Redis instance
# e.g. start one with: docker run -d -p 6379:6379 redis:7-alpine
REDIS_URL=redis://localhost:6379

# Media and Upload Configuration
MEDIA_URL=/uploads/
MEDIA_ROOT=/app/uploads

# Upload folder structure (customize for your needs)
MEMBER_UPLOAD_FOLDER=members/avatars
ATTACHMENT_UPLOAD_FOLDER=attachments

# Optional resource limits (if you need to override docker-compose defaults)
#DB_MEMORY_LIMIT=1G
#REDIS_MEMORY_LIMIT=256M
#APP_MEMORY_LIMIT=2G

# Email Configuration
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_username
EMAIL_HOST_PASSWORD=your_password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=noreply@example.com

# Frontend URL used in password reset emails sent to users
# Set this to the public URL of your frontend, e.g. https://jf.yourdomain.com
FRONTEND_URL=http://localhost:5173

# Timezone (defaults to Europe/Berlin)
TIME_ZONE=Europe/Berlin
