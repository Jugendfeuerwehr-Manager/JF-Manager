# ==============================================
# JF-Manager Portainer Stack Environment Variables
# ==============================================
# Copy this file content to Portainer Stack's "Environment variables" section
# Or use "Load variables from .env file" feature

# PostgreSQL Configuration
POSTGRES_DB=jf_manager_backend
POSTGRES_USER=jf_manager
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# Django Configuration
DJANGO_SECRET_KEY=CHANGE_ME_TO_RANDOM_50_CHARS
DJANGO_ADMIN_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
DJANGO_ADMIN_EMAIL=admin@yourdomain.com
DJANGO_MANAGEPY_MIGRATE=on
DEBUG=False

# Security Settings - IMPORTANT: Set your actual domain!
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,localhost
# CSRF_TRUSTED_ORIGINS: Must include full URL scheme (https://)
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Frontend Configuration
# For production behind nginx reverse proxy, use relative path:
VITE_API_BASE_URL=/api/v1
# For direct access without reverse proxy, use full URL:
# VITE_API_BASE_URL=https://yourdomain.com/api/v1

# Email Configuration (Optional but recommended)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@example.com
EMAIL_HOST_PASSWORD=your_email_password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Port Configuration (Optional, defaults to 80/443)
HTTP_PORT=80
HTTPS_PORT=443

# ==============================================
# Password Generation Commands (Run locally):
# ==============================================
# PostgreSQL: openssl rand -base64 32
# Django Secret: openssl rand -base64 50
# Admin Password: openssl rand -base64 16
